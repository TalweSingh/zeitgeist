# Anthropic API key — powers the agent loop (Claude Sonnet 4.6 + Opus 4.7 fallback)
ANTHROPIC_API_KEY=

# Perplexity — used by findJobs tool to scrape open roles in one shot
PERPLEXITY_API_KEY=

# Firecrawl — used by scrapeCompany + scrapeProfile tools. Paste-in fallback if missing
FIRECRAWL_API_KEY=

# SerpAPI — optional; powers searchWeb tool. Mocked when unset
SERPAPI_KEY=

# X channel mode: "mock" routes to the fake adapter; "real" routes to lib/channels/x/real.ts
ZEITGEIST_X_MODE=mock

# X OAuth 2.0 PKCE — fill in when going live (see lib/channels/x/real.ts header)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/channels/x/oauth/callback
